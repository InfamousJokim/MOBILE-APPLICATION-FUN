<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ── Stars decoration (top corners) ── -->
        <TextView
            android:id="@+id/starTopLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="24sp"
            android:textColor="#4040A0"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/starTopRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="18sp"
            android:textColor="#4040A0"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Game title ── -->
        <TextView
            android:id="@+id/gameIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮"
            android:textSize="64sp"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/gameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game_title"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="0.15"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/gameIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/gameSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game_subtitle"
            android:textSize="14sp"
            android:textColor="@color/secondary"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/gameTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Player info card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/playerCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/dark_card"
            app:layout_constraintTop_toBottomOf="@id/gameSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/welcomeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    tools:text="Welcome back,\nPlayer!" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A6A"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- Score row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/best_score"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/bestScoreText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_score_yet"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/game_streak_gold"
                        tools:text="🏆 240 pts" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── PLAY button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/playButton"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="28dp"
            android:text="@string/btn_play_now"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.15"
            app:backgroundTint="@color/primary"
            app:cornerRadius="36dp"
            app:rippleColor="#9951CAFF"
            app:layout_constraintTop_toBottomOf="@id/playerCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Leaderboard button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/leaderboardButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_leaderboard"
            android:textSize="16sp"
            android:textColor="@color/secondary"
            app:backgroundTint="#00000000"
            app:strokeColor="@color/secondary"
            app:strokeWidth="2dp"
            app:cornerRadius="28dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:layout_constraintTop_toBottomOf="@id/playButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Hint text ── -->
        <TextView
            android:id="@+id/hintText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/home_hint"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/leaderboardButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Bottom decoration ── -->
        <TextView
            android:id="@+id/starBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  ·  ✦  ·  ✦"
            android:textSize="12sp"
            android:textColor="#4040A0"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/hintText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
